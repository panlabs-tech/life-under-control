# Variáveis exigidas pelo @luc/web. No dev, copie para .env (gitignored); em
# produção, configure no Coolify. Nenhum valor real entra no git.
# Para rodar local com Docker (Postgres + MinIO), ver docs/agents/local-dev.md —
# o apps/web/.env.local já traz os valores de dev prontos.

# Banco Postgres. Em produção o Coolify injeta a URL do serviço luc-db.
DATABASE_URL=postgres://luc:luc@localhost:5432/luc

# Auth.js v5 — segredo de assinatura da sessão JWT. Gere com: openssl rand -hex 32
AUTH_SECRET=

# OAuth Google (Google Cloud Console → Credenciais → ID do cliente OAuth 2.0).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Allowlist do Lar (ADR-0004): exatamente 2 e-mails Google, separados por vírgula.
LUC_ALLOWLIST=
# Somente em dev local: pula o OAuth para validar a interface com o seed local.
LUC_LOCAL_AUTH_BYPASS=false

# Comprovantes no Cloudflare R2 (ADR-0008). ACCOUNT_ID é o id da conta Cloudflare
# (o mesmo do endpoint S3 https://<ACCOUNT_ID>.r2.cloudflarestorage.com); o par
# ACCESS_KEY/SECRET vem de um R2 API Token (S3 Auth); BUCKET é o bucket criado.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=luc-attachments
# Opcional no desenvolvimento: endpoint S3 local (ex.: MinIO). Ausente em produção.
R2_ENDPOINT=

# Bedrock (ADR-0013) — extração de comprovante por vision. Credencial IAM
# dedicada (nunca o usuário admin) com policy escopada só a
# bedrock:InvokeModel/InvokeModelWithResponseStream no ARN do inference
# profile do modelo. ID exato confirmado por smoke real (comprovante de gás,
# JSON estruturado) na #154: us.anthropic.claude-opus-4-6-v1 (inference
# profile, us-east-1). Opus 4.7/4.8 ficaram de fora: entitlement veio
# AVAILABLE mas InvokeModel seguiu AccessDenied — rollout de capacidade da
# AWS/Anthropic pros modelos mais novos, não bureaucracy de acesso.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# Opcional: sobrescreve o inference profile. Default = us.anthropic.claude-opus-4-6-v1.
BEDROCK_MODEL_ID=

# WhatsApp Cloud API (ADR-0012) — webhook seguro + eco (#155). Todos os 5
# configurados no app da Meta / Business Manager, já ativos em produção via
# Coolify (#153). ACCESS_TOKEN é de system user (não expira como token de
# usuário); VERIFY_TOKEN é escolhido por nós e cadastrado igual no painel
# da Meta; APP_SECRET assina o corpo do webhook (HMAC-SHA256).
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WABA_ID=
WHATSAPP_VERIFY_TOKEN=
META_APP_SECRET=
