{
  "$schema": "https://biomejs.dev/schemas/2.0.0/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": ["**", "!**/.next/**", "!**/node_modules/**", "!**/*.css"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "asNeeded"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "overrides": [
    {
      "includes": ["apps/web/src/core/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "paths": {
                  "next": "core/ é puro: a borda Next nunca entra no núcleo (ADR-0003).",
                  "next/server": "core/ é puro: a borda Next nunca entra no núcleo (ADR-0003).",
                  "next/navigation": "core/ é puro: a borda Next nunca entra no núcleo (ADR-0003).",
                  "next/headers": "core/ é puro: a borda Next nunca entra no núcleo (ADR-0003).",
                  "react": "core/ é puro: sem React (ADR-0003).",
                  "react-dom": "core/ é puro: sem React (ADR-0003).",
                  "drizzle-orm": "core/ não fala com o store: use um port, não Drizzle (ADR-0003).",
                  "pg": "core/ não fala com o banco direto: use um port (ADR-0003)."
                }
              }
            }
          }
        }
      }
    }
  ]
}
