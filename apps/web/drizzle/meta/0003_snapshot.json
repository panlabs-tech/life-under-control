        "bills_estado_check": {
          "name": "bills_estado_check",
          "value": "\"bills\".\"estado\" in ('ativa', 'encerrada')"
        },
        "bills_encerramento_check": {
          "name": "bills_encerramento_check",
          "value": "(\"bills\".\"estado\" = 'encerrada') = (\"bills\".\"encerrada_em\" is not null)"
        },
        "bills_due_rule_kind_check": {
          "name": "bills_due_rule_kind_check",
          "value": "\"bills\".\"due_rule_kind\" in ('dia-fixo', 'n-esimo-dia-util', 'ultimo-dia-util')"
        },
        "bills_interval_months_check": {
          "name": "bills_interval_months_check",
          "value": "\"bills\".\"interval_months\" >= 1"
        },
        "bills_due_month_offset_check": {
          "name": "bills_due_month_offset_check",
          "value": "\"bills\".\"due_month_offset\" >= 0"
        },
        "bills_recurrence_anchor_check": {
          "name": "bills_recurrence_anchor_check",
          "value": "(\"bills\".\"interval_months\" = 1 and \"bills\".\"anchor_month\" is null) or (\"bills\".\"interval_months\" > 1 and \"bills\".\"anchor_month\" between 1 and 12)"
        },
        "bills_due_rule_shape_check": {
          "name": "bills_due_rule_shape_check",
          "value": "(\"bills\".\"due_rule_kind\" = 'dia-fixo') = (\"bills\".\"due_rule_day\" is not null)\n        and (\"bills\".\"due_rule_kind\" = 'n-esimo-dia-util') = (\"bills\".\"due_rule_nth\" is not null)\n        and (\"bills\".\"due_rule_day\" is null or \"bills\".\"due_rule_day\" between 1 and 31)\n        and (\"bills\".\"due_rule_nth\" is null or \"bills\".\"due_rule_nth\" between 1 and 23)"
        }
      },
